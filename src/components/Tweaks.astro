---
// Tweaks panel · client-only behavior
---
<div id="tweaks">
  <h4>// TWEAKS <button id="tweaks-close">×</button></h4>
  <div class="field">
    <label>ACCENT COLOR</label>
    <div class="swatches">
      <div class="sw active" data-accent="#C7F23D" style="background:#C7F23D"></div>
      <div class="sw" data-accent="#D4FF3A" style="background:#D4FF3A"></div>
      <div class="sw" data-accent="#B8F000" style="background:#B8F000"></div>
      <div class="sw" data-accent="#FF4500" style="background:#FF4500"></div>
      <div class="sw" data-accent="#00E5FF" style="background:#00E5FF"></div>
      <div class="sw" data-accent="#FFFFFF" style="background:#FFFFFF"></div>
    </div>
  </div>
  <div class="field">
    <label>GRAIN · TEXTURA <span id="grain-val" style="color:var(--accent)">55</span>%</label>
    <input type="range" id="grain" min="0" max="100" step="5" value="55" />
  </div>
  <div class="field">
    <label>DENSIDAD <span id="density-val" style="color:var(--accent)">1.00</span>x</label>
    <input type="range" id="density" min="0.7" max="1.3" step="0.05" value="1" />
  </div>
  <div class="field">
    <label style="color:var(--fg-dim)">PULSA <b style="color:var(--accent)">T</b> PARA ABRIR/CERRAR</label>
  </div>
</div>

<script>
  type TweakState = { accent: string; grain: number; density: number };

  /* ── Theme helpers ── */
  function getEffectiveTheme(): 'dark' | 'light' {
    const h = document.documentElement;
    if (h.classList.contains('dark')) return 'dark';
    if (h.classList.contains('light')) return 'light';
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  const THEME_DEFAULTS: Record<'dark' | 'light', TweakState> = {
    dark:  { accent: '#C7F23D', grain: 55, density: 1 },
    light: { accent: '#4a6a14', grain: 18, density: 1 },
  };

  /* Per-theme swatch palettes */
  const THEME_SWATCHES: Record<'dark' | 'light', string[]> = {
    dark:  ['#C7F23D', '#D4FF3A', '#B8F000', '#FF4500', '#00E5FF', '#FFFFFF'],
    light: ['#4a6a14', '#587611', '#3d6b0a', '#b35400', '#0066cc', '#8b0000'],
  };

  /* Separate storage keys per theme so they don't bleed into each other */
  const STORAGE_KEYS: Record<'dark' | 'light', string> = {
    dark:  'mc.tweaks.dark.v1',
    light: 'mc.tweaks.light.v1',
  };

  const tweaksEl = document.getElementById('tweaks')!;
  const grainInput = document.getElementById('grain') as HTMLInputElement;
  const densityInput = document.getElementById('density') as HTMLInputElement;
  const grainVal = document.getElementById('grain-val')!;
  const densityVal = document.getElementById('density-val')!;

  function load(): TweakState {
    const theme = getEffectiveTheme();
    const defaults = THEME_DEFAULTS[theme];
    try {
      const raw = localStorage.getItem(STORAGE_KEYS[theme]);
      if (raw) return { ...defaults, ...(JSON.parse(raw) as Partial<TweakState>) };
    } catch {}
    return { ...defaults };
  }

  function save(s: TweakState) {
    try { localStorage.setItem(STORAGE_KEYS[getEffectiveTheme()], JSON.stringify(s)); } catch {}
  }

  function updateSwatches(currentAccent: string) {
    const swColors = THEME_SWATCHES[getEffectiveTheme()];
    document.querySelectorAll<HTMLElement>('#tweaks .sw').forEach((sw, i) => {
      const color = swColors[i] ?? swColors[0] ?? '';
      sw.dataset.accent = color;
      sw.style.background = color;
      sw.classList.toggle('active', color.toLowerCase() === currentAccent.toLowerCase());
    });
  }

  function apply(t: TweakState) {
    document.documentElement.style.setProperty('--accent', t.accent);
    document.documentElement.style.setProperty('--grain-opacity', (t.grain / 100).toFixed(2));
    document.documentElement.style.setProperty('--density', String(t.density));
    grainInput.value = String(t.grain);
    densityInput.value = String(t.density);
    grainVal.textContent = String(t.grain);
    densityVal.textContent = Number(t.density).toFixed(2);
    updateSwatches(t.accent);
  }

  const state = load();
  apply(state);

  function setKeys(edits: Partial<TweakState>) {
    Object.assign(state, edits);
    apply(state);
    save(state);
  }

  document.querySelectorAll<HTMLElement>('#tweaks .sw').forEach((sw) => {
    sw.addEventListener('click', () => setKeys({ accent: sw.dataset.accent! }));
  });
  grainInput.addEventListener('input', () => setKeys({ grain: Number(grainInput.value) }));
  densityInput.addEventListener('input', () => setKeys({ density: Number(densityInput.value) }));

  document.getElementById('tweaks-close')!.addEventListener('click', () => {
    tweaksEl.classList.remove('open');
  });

  window.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA')) return;
    if (e.key === 't' || e.key === 'T') tweaksEl.classList.toggle('open');
  });

  // Scroll reveal (shared global behavior)
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
